# Required
ANTHROPIC_AUTH_TOKEN=sk-ant-...

# Optional
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
AGENT_SERVICE_PORT=8000

# Session TTL (minutes)
SB_TTL_MINUTES=30

# AWS Bedrock (optional) - only needed if using Bedrock instead of Anthropic API
# ANTHROPIC_BEDROCK_BASE_URL=
# AWS_REGION=us-east-1
# AWS_PROFILE=
# CLAUDE_CODE_USE_BEDROCK=1
