# Required
ANTHROPIC_AUTH_TOKEN=sk-ant-...

# Optional
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
AGENT_SERVICE_PORT=8000

# Session TTL (minutes)
SB_TTL_MINUTES=30

# AWS Bedrock (optional) - only needed if using Bedrock instead of Anthropic API
# ANTHROPIC_BEDROCK_BASE_URL=
# AWS_REGION=us-east-1
# AWS_PROFILE=
# CLAUDE_CODE_USE_BEDROCK=1

# Sandbox mode: 'local' (default) uses local Docker socket,
# 'remote' connects to a Docker host via SSH
SANDBOX_MODE=local

# Remote Docker host (only needed when SANDBOX_MODE=remote)
# DOCKER_HOST_HOST=ec2-b.compute.amazonaws.com
# DOCKER_HOST_USER=agent
# DOCKER_HOST_KEY_PATH=~/.ssh/ec2-docker.pem

# Sandbox Docker image
SANDBOX_DOCKER_IMAGE=codenano-sandbox:latest